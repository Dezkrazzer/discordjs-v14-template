# ═══════════════════════════════════════════════════════════════════════════════
# Environment Variables — .env.example
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Discord Bot Token ──────────────────────────────────────────────────────
# Get yours at: https://discord.com/developers/applications
#
# SINGLE BOT (Sharding Mode):
#   DISCORD_TOKEN=your_bot_token_here
#
# MULTI-BOT MODE:
#   Set comma-separated tokens to run multiple bots in one process.
#   The first token becomes the "primary" bot for command delegation.
#   DISCORD_TOKEN=token_bot_1,token_bot_2,token_bot_3
#
DISCORD_TOKEN=your_bot_token_here

# ─── Developer Mode Settings ───────────────────────────────────────────────
# Guild ID where slash commands register instantly in dev mode.
DEV_GUILD_ID=your_dev_guild_id_here

# Comma-separated Discord user IDs allowed to use devOnly commands.
DEV_IDS=your_user_id_here,another_user_id_here